#     cmake -S /tmp/xtl -B /tmp/xtl/build -DCMAKE_INSTALL_PREFIX=/usr/local
#     cmake --install /tmp/xtl/build
#     rm -rf /tmp/xtl
#
#     # xtensor (header-only)
#     git clone --depth 1 --branch 0.25.0 https://github.com/xtensor-stack/xtensor.git /tmp/xtensor
#     cmake -S /tmp/xtensor -B /tmp/xtensor/build -DCMAKE_INSTALL_PREFIX=/usr/local
#     cmake --install /tmp/xtensor/build
#     rm -rf /tmp/xtensor
#
#     # xbioclim with CUDA
#     git clone https://github.com/alrobles/xbioclim.git /opt/xbioclim
#     cd /opt/xbioclim
#
#     cmake -B build \
#         -DCMAKE_BUILD_TYPE=Release \
#         -DXBIOCLIM_BUILD_TESTS=OFF \
#         -DXBIOCLIM_USE_OPENMP=ON \
#         -DXBIOCLIM_USE_CUDA=ON
#
#     cmake --build build --parallel $(nproc)
#     cmake --install build --prefix /usr/local
#     rm -rf /opt/xbioclim/build

%environment
    export PATH=/usr/local/bin:$PATH

%runscript
    exec xbioclim_cli "$@"
